        "pattern": "(?P<result>Accepted|Failed) (?P<auth_method>\\w+) for (?:invalid user )?(?P<user>\\S+) from (?P<src>[\\d.]+) port (?P<src_port>\\d+)",
        "parent": 0,
        "state": "active",
        "types": {
          "auth_method": "any",
          "result": "any",
          "src": "any",
          "src_port": "int",
          "user": "any"
        },
        "input": "msg",
        "guard": [],
        "ops": [
          {
            "op": "set",
            "field": "app",
            "value": "ssh",
            "when": null
          },
          {
            "op": "set",
            "field": "action",
            "value": "success",
            "when": {
              "field": "result",
              "op": "eq",
              "value": "Accepted"
            }
          },
          {
            "op": "set",
            "field": "action",
            "value": "failure",
            "when": {
              "field": "result",
              "op": "eq",
              "value": "Failed"
            }
